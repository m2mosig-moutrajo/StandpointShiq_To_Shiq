<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/demo/"
     xml:base="http://www.semanticweb.org/demo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:demo="http://www.semanticweb.org/demo#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:untitled-ontology-223="http://www.semanticweb.org/omar/ontologies/2026/5/untitled-ontology-223#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/demo">
        <demo:standpointFormula>&lt;formula op=&quot;box&quot; standpoint=&quot;*&quot;&gt;
  &lt;intersection&gt;
    &lt;literal ref=&quot;F4&quot;/&gt;
    &lt;literal ref=&quot;F5&quot;/&gt;
  &lt;/intersection&gt;
&lt;/formula&gt;</demo:standpointFormula>
        <demo:standpointFormula>&lt;formula op=&quot;box&quot; standpoint=&quot;InfoSci&quot;&gt;
  &lt;literal ref=&quot;F1&quot;/&gt;
&lt;/formula&gt;</demo:standpointFormula>
        <demo:standpointFormula>&lt;formula op=&quot;box&quot; standpoint=&quot;OS&quot;&gt;
  &lt;intersection&gt;
    &lt;literal ref=&quot;F2&quot;/&gt;
    &lt;literal ref=&quot;F3&quot;/&gt;
  &lt;/intersection&gt;
&lt;/formula&gt;</demo:standpointFormula>
    </owl:Ontology>
    


