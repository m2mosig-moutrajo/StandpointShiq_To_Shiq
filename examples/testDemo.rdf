    <!-- http://www.semanticweb.org/demo#ByteSequence -->

    <owl:Class rdf:about="http://www.semanticweb.org/demo#ByteSequence"/>
    


    <!-- http://www.semanticweb.org/demo#File -->

    <owl:Class rdf:about="http://www.semanticweb.org/demo#File">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/demo#ByteSequence"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/demo#InformationObject"/>
        <rdfs:subClassOf rdf:nodeID="genid3"/>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid3">
        <owl:onProperty rdf:resource="http://www.semanticweb.org/demo#encodes"/>
        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/demo#File"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/demo#File"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/demo#ByteSequence"/>
        <demo:standpointAxiom>&lt;axiom id=&quot;F2&quot;&gt;&lt;/axiom&gt;</demo:standpointAxiom>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/demo#File"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/demo#InformationObject"/>
        <demo:standpointAxiom>&lt;axiom id=&quot;F1&quot;&gt;&lt;/axiom&gt;</demo:standpointAxiom>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/demo#File"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid3"/>
        <demo:standpointAxiom>&lt;axiom id=&quot;F3&quot;&gt;
  File SubClassOf:
    encodes some &lt;modal op=&quot;diamond&quot; standpoint=&quot;InfoSci&quot;&gt;File&lt;/modal&gt;
&lt;/axiom&gt;</demo:standpointAxiom>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/demo#InformationObject -->

    <owl:Class rdf:about="http://www.semanticweb.org/demo#InformationObject"/>
    


    <!-- http://www.w3.org/2002/07/owl#Nothing -->

    <owl:Class rdf:about="http://www.w3.org/2002/07/owl#Nothing"/>
    


